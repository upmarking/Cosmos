<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Cosmos" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        
        <!-- Android 12+ System Splash Screen Overrides -->
        <!-- Set the background of the system splash to black -->
        <item name="android:windowSplashScreenBackground">@android:color/black</item>
        <!-- Hide the default system launcher icon logo on launch -->
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
    </style>
</resources>
