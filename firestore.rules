rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Checks if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Checks if document belongs to the signed-in user
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper: Checks if user is a member of the connection
    function isConnectionMember(connectionId) {
      return isSignedIn() && (
        connectionId.matches('.*' + request.auth.uid + '.*') ||
        request.auth.uid in get(/databases/$(database)/documents/connections/$(connectionId)).data.members
      );
    }

    // 1. Users collection rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
                    || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['connectionsCount', 'followersCount', 'followingCount', 'joinedCircles', 'pendingCircles']))
                    || (isSignedIn() && userId.matches('mock_user_.*'));

      match /skills/{skillId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // 2. Swipes collection rules
    match /swipes/{swipeId} {
      allow read: if isSignedIn() && resource.data.likerId == request.auth.uid;
      allow create, update: if isSignedIn() && request.auth.uid == request.resource.data.likerId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.likerId;
    }

    // 3. Connections collection rules
    match /connections/{connectionId} {
      allow read: if isSignedIn() && (
        resource == null ||
        request.auth.uid in resource.data.members ||
        connectionId.matches('.*' + request.auth.uid + '.*')
      );
      // Allow creation of connection if user is one of the members
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;
      // Allow updates to labels, goal, status if user is member
      allow update: if isSignedIn() && request.auth.uid in resource.data.members;
      allow delete: if isSignedIn() && request.auth.uid in resource.data.members;

      match /messages/{messageId} {
        allow read, write: if isConnectionMember(connectionId);
      }
    }

    // 4. Events collection rules
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantCount'])
      );
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;

      match /registrants/{userId} {
        allow read: if isSignedIn() && (
          isOwner(userId) || 
          get(/databases/$(database)/documents/events/$(eventId)).data.createdBy == request.auth.uid
        );
        allow write: if isSignedIn() && (
          isOwner(userId) || 
          get(/databases/$(database)/documents/events/$(eventId)).data.createdBy == request.auth.uid
        );
      }

      match /rounds/{roundId} {
        allow read, write: if isSignedIn();

        match /feedback/{feedbackId} {
          allow read, write: if isSignedIn();
        }
      }
    }

    // 5. Circles collection rules
    match /circles/{circleId} {
      allow read: if isSignedIn();
      // Allow creator to update everything, other users can only increment/decrement memberCount (joining/leaving)
      allow update: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount'])
      );
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;

      match /members/{userId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId) || (isSignedIn() && (userId.matches('mock_user_.*') || get(/databases/$(database)/documents/circles/$(circleId)).data.createdBy == request.auth.uid));
      }

      match /posts/{postId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        // Allow creator of post OR creator of circle to update/delete posts
        allow update, delete: if isSignedIn() && (
          resource.data.authorId == request.auth.uid ||
          get(/databases/$(database)/documents/circles/$(circleId)).data.createdBy == request.auth.uid
        );
      }
    }

    // 10. Social Posts collection rules
    match /social_posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likesCount', 'repliesCount']));

      match /replies/{replyId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      }
    }

    // 6. Connection Requests collection rules
    match /connection_requests/{requestId} {
      // Allow reading request if user is sender or receiver, or if document does not exist (for check before creation)
      allow read: if isSignedIn() && (
        resource == null ||
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
      // Allow creating a request if the sender matches the authenticated user
      allow create: if isSignedIn() && (
        request.auth.uid == request.resource.data.senderId
      );
      // Allow updating request status/details if user is sender or receiver
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.receiverId ||
        request.auth.uid == resource.data.senderId ||
        request.auth.uid == request.resource.data.senderId ||
        request.auth.uid == request.resource.data.receiverId
      );
      allow delete: if false;
    }

    // 7. Notifications collection rules
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      // Allow creation if signed in. Ideally, sensitive notifications should be
      // created via Cloud Functions, but this allows client-side notification triggers.
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource == null || (resource.data.userId == request.auth.uid && 
                   request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead'])));
      allow delete: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
    }

    // 8. Support tickets rules
    match /support_tickets/{ticketId} {
      // Ensure the ticket is associated with the authenticated user
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if false; // Only admin/backend processes tickets
    }

    // 9. Intro Requests collection rules
    match /intro_requests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.requesterId == request.auth.uid ||
        resource.data.targetId == request.auth.uid ||
        resource.data.connectorId == request.auth.uid
      );
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.requesterId;
      allow update: if isSignedIn() && request.auth.uid == resource.data.connectorId;
      allow delete: if false;
    }
  }
}
