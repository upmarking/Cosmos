rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Checks if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Checks if document belongs to the signed-in user
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper: Checks if user is a member of the connection
    function isConnectionMember(connectionId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/connections/$(connectionId)).data.members;
    }

    // 1. Users collection rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // 2. Swipes collection rules
    match /swipes/{swipeId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == request.resource.data.likerId;
      allow delete: if false;
    }

    // 3. Connections collection rules
    match /connections/{connectionId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.members;
      // Allow creation of connection if user is one of the members
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;
      // Allow updates to labels, goal, status if user is member
      allow update: if isSignedIn() && request.auth.uid in resource.data.members;
      allow delete: if false;

      match /messages/{messageId} {
        allow read, write: if isConnectionMember(connectionId);
      }
    }

    // 4. Events collection rules
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if false; // Admins create events

      match /registrants/{userId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }
    }

    // 5. Circles collection rules
    match /circles/{circleId} {
      allow read: if isSignedIn();
      // Allow join transaction to increment memberCount
      allow update: if isSignedIn();
      allow create, delete: if false;

      match /members/{userId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      match /posts/{postId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (
          resource.data.authorName == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name
        );
      }
    }

    // 6. Notifications collection rules
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Let clients create notifications (e.g., when warm intro is requested) or mark as read
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && 
                   request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
